{
  "name": "flowloom",
  "version": "0.14.2",
  "description": "DeepSeek FlowLoom — an open-source, DeepSeek-native agentic coding CLI rivaling Claude Code.",
  "type": "module",
  "bin": {
    "floom": "./dist/cli.js"
  },
  "engines": {
    "node": ">=24"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE",
    "CONTRIBUTING.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Renn-rpg/flowloom.git"
  },
  "keywords": [
    "deepseek",
    "agentic",
    "coding",
    "cli",
    "ai",
    "workflow",
    "llm",
    "code-assistant",
    "flowloom",
    "claude-code"
  ],
  "author": "FlowLoom Contributors",
  "license": "MIT",
  "homepage": "https://github.com/Renn-rpg/flowloom#readme",
  "bugs": {
    "url": "https://github.com/Renn-rpg/flowloom/issues"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "probe": "tsx scripts/probe.ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^12.1.0",
    "dotenv": "^17.4.2",
    "openai": "^4.77.0",
    "ora": "^9.4.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "optionalDependencies": {
    "isolated-vm": "^5.0.0"
  }
}
