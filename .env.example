DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
# 默认模型。deepseek-v4-pro 为 thinking+工具模型（用户已实测可用）；如需更快/更省可改 deepseek-chat。
DEEPSEEK_MODEL=deepseek-v4-pro

# --effort high/max 切换到的「会思考又能用工具」的模型 id（thinking mode）。
# 注意：deepseek-reasoner 不支持工具调用，不能填它；文档示例为 deepseek-v4-pro，
# 但需你用真实 key 确认账户已开放该模型后再填（不臆造）。留空则 --effort high 告警并回退基础模型。
# FLOOM_REASONER_MODEL=deepseek-v4-pro

# ── 可选：运行时安全/资源阈值（不臆造 DeepSeek 数字，按需自行设置）──
# run_shell 单条命令超时（毫秒），默认 120000
# FLOOM_SHELL_TIMEOUT_MS=120000
# web_fetch 超时（毫秒），默认 15000
# FLOOM_FETCH_TIMEOUT_MS=15000
# 单次响应 max_tokens（客户端请求参数，非模型固有窗口），默认 8192。
# thinking 模型的 CoT 与最终答案共用此额度，太小会截断；如答案被截可调高（确保不超过该模型的 max output）。
# FLOOM_MAX_TOKENS=8192
# 自我保护用的上下文 token 预算：≈4 字符/token 的粗略估算（非 DeepSeek 官方窗口）。
# 设为你所用模型上下文窗口留足余量后的值；估算超过它时从最旧对话轮开始整轮丢弃。
# 默认 0 = 关闭（保持当前行为，不做任何窗口假设）。
# FLOOM_CONTEXT_TOKENS=0
